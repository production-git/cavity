{
  "name": "cavity",
  "version": "0.1.0",
  "description": "Crystal structure viewer — HKUST-1 MOF editor",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='tests/(unit|integration)'",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='tests/(unit|integration)' --coverage",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "three": "^0.160.0"
  }
}
